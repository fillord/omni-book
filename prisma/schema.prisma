generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                    String     @id @default(cuid())
  slug                  String     @unique
  name                  String
  niche                 String?
  plan                  Plan       @default(FREE)
  planStatus            PlanStatus @default(ACTIVE)
  maxResources          Int        @default(1)
  subscriptionExpiresAt DateTime?
  isActive              Boolean    @default(true)
  timezone     String     @default("Asia/Almaty")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  address      String?
  city         String?
  coverUrl     String?
  description  String?
  email        String?
  logoUrl      String?
  phone        String?
  socialLinks  Json       @default("{}")
  translations Json       @default("{}")
  website      String?
  workingHours    String?
  bookingWindowDays Int        @default(14)
  telegramChatId  String?
  bookings        Booking[]
  resources    Resource[]
  services     Service[]
  users        User[]
  notifications  Notification[]
  auditLogs      AuditLog[]
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  body      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model Notification {
  id        String   @id @default(cuid())
  tenantId  String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, read])
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  eventType String
  details   Json     @default("{}")
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([eventType])
  @@index([createdAt])
}

model User {
  id            String    @id @default(cuid())
  tenantId      String?
  email         String    @unique
  name          String?
  phone         String?
  passwordHash  String?
  lastIpAddress String?
  role          Role      @default(CUSTOMER)
  emailVerified DateTime?
  activeSessionId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  bookings      Booking[]
  tenant        Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([email])
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  @@unique([email, code])
}

model Resource {
  id          String            @id @default(cuid())
  tenantId    String
  name        String
  type        String
  description String?
  capacity    Int?
  attributes  Json              @default("{}")
  translations Json             @default("{}")
  lunchStart  String?
  lunchEnd    String?
  isActive    Boolean           @default(true)
  isFrozen    Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  bookings    Booking[]
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  services    ResourceService[]
  schedules   Schedule[]

  @@index([tenantId])
  @@index([tenantId, type])
}

model Schedule {
  id         String   @id @default(cuid())
  resourceId String
  dayOfWeek  Int
  startTime  String
  endTime    String
  isActive   Boolean  @default(true)
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([resourceId, dayOfWeek])
  @@index([resourceId])
}

model Service {
  id          String            @id @default(cuid())
  tenantId    String
  name        String
  description String?
  durationMin Int
  price       Int?
  currency    String            @default("KZT")
  translations Json             @default("{}")
  isActive    Boolean           @default(true)
  isFrozen    Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  bookings    Booking[]
  resources   ResourceService[]
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model ResourceService {
  resourceId String
  serviceId  String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  service    Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([resourceId, serviceId])
}

model Booking {
  id             String        @id @default(cuid())
  tenantId       String
  resourceId     String
  serviceId      String?
  userId         String?
  guestName      String?
  guestPhone     String?
  guestEmail     String?
  startsAt       DateTime
  endsAt         DateTime
  status         BookingStatus @default(CONFIRMED)
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  reminder24hSentAt DateTime?
  reminder2hSentAt  DateTime?
  reminder1hSentAt  DateTime?
  resource       Resource      @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  service        Service?      @relation(fields: [serviceId], references: [id])
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user           User?         @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([tenantId, resourceId, startsAt])
  @@index([tenantId, status])
  @@index([userId])
  @@index([startsAt, reminder24hSentAt])
  @@index([startsAt, reminder2hSentAt])
  @@index([startsAt, reminder1hSentAt])
}

enum Role {
  SUPERADMIN
  OWNER
  STAFF
  CUSTOMER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum PlanStatus {
  ACTIVE
  PENDING
  EXPIRED
  BANNED
  CANCELED
}
