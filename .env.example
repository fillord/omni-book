# App
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-me-with-a-secure-random-string
ROOT_DOMAIN=omnibook.com

# Cron job authorization (required for Vercel Cron)
# Generate a random string: openssl rand -hex 32
CRON_SECRET=

# Google OAuth (optional — enables "Sign in with Google")
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_ENABLED=false

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/omnibook

# (Optional) Redis — for session store / job queue
REDIS_URL=redis://localhost:6379

# Upstash Redis (required — rate limiting)
# Create a database at https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Email (Resend — required for booking confirmations)
# Get API key at https://resend.com/api-keys
RESEND_API_KEY=

# Meta / WhatsApp webhook (optional — for WhatsApp Business inbound)
META_WEBHOOK_VERIFY_TOKEN=

# Telegram Bot
TELEGRAM_BOT_TOKEN=                    # BotFather token
ADMIN_TELEGRAM_CHAT_ID=                # Your personal chat ID (get via @userinfobot)
TELEGRAM_WEBHOOK_SECRET=               # Random string; pass as secret_token when registering webhook

# Paylink.kz payment gateway
PAYLINK_API_KEY=
PAYLINK_WEBHOOK_SECRET=
PAYLINK_API_URL=https://api.paylink.kz
NEXT_PUBLIC_APP_URL=https://omni-book.site
